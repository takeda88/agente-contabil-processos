"""
Agente Contabil Principal - Orquestrador do sistema
Integra todos os modulos e coordena as acoes do agente de IA
"""

import logging
import os
from datetime import datetime
from typing import Optional

logger = logging.getLogger(__name__)


class AgenteContabil:
    """
    Orquestrador principal do Agente Contabil.
    Coordena todos os modulos e fornece interface unificada
    para automacoes do Departamento de Processos.
    """

    def __init__(self):
        self.logger = logging.getLogger(self.__class__.__name__)
        self._inicializar_modulos()
        self.logger.info("AgenteContabil inicializado")

    def _inicializar_modulos(self):
        """Inicializa todos os modulos do agente"""
        from modulos.email_module import EmailModule
        from modulos.whatsapp_module import WhatsAppModule
        from modulos.planilhas_module import PlanilhasModule
        from modulos.word_module import WordModule
        from modulos.pastas_module import PastasModule
        from modulos.web_scraping_module import WebScrapingModule
        from modulos.pdf_module import PdfModule 
        from modulos.sped_module import SpedModule
        from modulos.notificacoes_module import NotificacoesModule
        from contabilidade.classificador import ClassificadorContabil
        from contabilidade.conciliacao import ConciliacaoBancaria
        from contabilidade.vencimentos import ControleVencimentos
        from contabilidade.relatorios import RelatoriosContabeis
        from contabilidade.obrigacoes import ObrigacoesAcessorias

        self.email = EmailModule()
        self.whatsapp = WhatsAppModule()
        self.planilhas = PlanilhasModule()
        self.word = WordModule()
        self.pastas = PastasModule()
        self.scraping = WebScrapingModule()
        self.pdf = ()
        self.sped = SPEDModule()
        self.notificacoes = NotificacoesModule(self.email, self.whatsapp)
        self.classificador = ClassificadorContabil()
        self.conciliacao = ConciliacaoBancaria(self.classificador)
        self.vencimentos = ControleVencimentos()
        self.relatorios = RelatoriosContabeis(self.planilhas)
        self.obrigacoes = ObrigacoesAcessorias()

    # =========================================================
    # PROCESSAMENTO DE E-MAIL
    # =========================================================

    def processar_emails(self):
        """
        Le, classifica e responde e-mails pendentes.
        - Identifica e-mails de clientes com duvidas contabeis
        - Classifica por tipo (fiscal, trabalhista, societario)
        - Responde automaticamente quando possivel
        - Encaminha para humano quando necessario
        """
        self.logger.info("Iniciando processamento de e-mails")
        emails = self.email.ler_emails_nao_lidos()
        self.logger.info(f"{len(emails)} e-mails nao lidos encontrados")

        for email in emails:
            classificacao = self.classificador.classificar_email(email)
            resposta = self.classificador.gerar_resposta(email, classificacao)

            if resposta['automatica']:
                self.email.responder(email, resposta['texto'])
                self.logger.info(f"E-mail respondido automaticamente: {email['assunto']}")
            else:
                self.email.marcar_para_revisao(email, classificacao)
                self.logger.info(f"E-mail marcado para revisao humana: {email['assunto']}")

        return emails

    # =========================================================
    # VENCIMENTOS E OBRIGACOES
    # =========================================================

    def verificar_vencimentos(self, dias_antecedencia: int = 5):
        """
        Verifica vencimentos proximos de:
        - DARF (IRPJ, CSLL, PIS, COFINS)
        - FGTS (dia 7 de cada mes)
        - INSS (dia 20 de cada mes)
        - ISS (varia por municipio)
        - ICMS (varia por estado)
        - Simples Nacional
        """
        self.logger.info(f"Verificando vencimentos para os proximos {dias_antecedencia} dias")
        vencimentos = self.vencimentos.buscar_proximos(dias_antecedencia)

        if vencimentos:
            self.logger.info(f"{len(vencimentos)} vencimentos encontrados")
            # Envia alertas
            self.notificacoes.alertar_vencimentos(vencimentos)
            # Gera planilha de controle
            self.planilhas.exportar_vencimentos(vencimentos)
        else:
            self.logger.info("Nenhum vencimento proximo encontrado")

        return vencimentos

    # =========================================================
    # RELATORIOS CONTABEIS
    # =========================================================

    def gerar_relatorio(self, tipo: str, periodo: Optional[str] = None):
        """
        Gera relatorios contabeis:
        - DRE (Demonstracao do Resultado do Exercicio)
        - Balancete de Verificacao
        - Balanco Patrimonial
        - Fluxo de Caixa
        - Relatorio de Clientes Inadimplentes
        """
        if periodo is None:
            periodo = datetime.now().strftime('%Y-%m')

        self.logger.info(f"Gerando relatorio: {tipo} - Periodo: {periodo}")
        relatorio = self.relatorios.gerar(tipo, periodo)

        # Salva como Excel
        caminho_excel = f"dados/relatorios/{tipo}_{periodo}.xlsx"
        self.planilhas.salvar(relatorio, caminho_excel)

        # Gera documento Word formatado
        caminho_word = f"dados/relatorios/{tipo}_{periodo}.docx"
        self.word.gerar_relatorio(relatorio, tipo, caminho_word)

        self.logger.info(f"Relatorio salvo em: {caminho_excel} e {caminho_word}")
        return relatorio

    # =========================================================
    # CONCILIACAO BANCARIA
    # =========================================================

    def conciliacao_bancaria(self, arquivo_extrato: str):
        """
        Realiza conciliacao bancaria automatizada:
        - Importa extrato OFX ou CSV
        - Compara com lancamentos contabeis
        - Identifica divergencias
        - Classifica lancamentos nao identificados
        - Gera relatorio de conciliacao
        """
        self.logger.info(f"Iniciando conciliacao bancaria: {arquivo_extrato}")
        resultado = self.conciliacao.processar(arquivo_extrato)

        caminho = f"dados/relatorios/conciliacao_{datetime.now().strftime('%Y%m%d')}.xlsx"
        self.planilhas.salvar_conciliacao(resultado, caminho)

        self.logger.info(f"Conciliacao concluida. {resultado['divergencias']} divergencias encontradas")
        return resultado

    # =========================================================
    # MONITORAMENTO DE PASTAS
    # =========================================================

    def monitorar_pasta(self, caminho: str):
        """
        Monitora pasta em tempo real:
        - Detecta novos arquivos (NF, boletos, contratos)
        - Classifica e move para pasta correta
        - Extrai dados de PDFs automaticamente
        - Notifica sobre novos documentos importantes
        """
        self.logger.info(f"Monitorando pasta: {caminho}")
        self.pastas.iniciar_monitoramento(
            caminho,
            callback=self._processar_novo_arquivo
        )

    def _processar_novo_arquivo(self, arquivo: str):
        """Callback para processar novos arquivos detectados"""
        extensao = os.path.splitext(arquivo)[1].lower()

        if extensao == '.pdf':
            dados = self.pdf.extrair_dados(arquivo)
            tipo_doc = self.pdf.classificar_documento(dados)
            destino = self.pastas.obter_pasta_destino(tipo_doc)
            self.pastas.mover(arquivo, destino)
            self.logger.info(f"PDF classificado como '{tipo_doc}' e movido para {destino}")

        elif extensao in ['.xlsx', '.xls']:
            analise = self.planilhas.analisar_automatico(arquivo)
            self.logger.info(f"Planilha analisada: {analise['resumo']}")

    # =========================================================
    # WHATSAPP
    # =========================================================

    def enviar_notificacoes_whatsapp(self):
        """
        Envia notificacoes via WhatsApp:
        - Alertas de vencimentos para clientes
        - Relatorios mensais resumidos
        - Confirmacoes de documentos recebidos
        - Avisos de irregularidades detectadas
        """
        self.logger.info("Enviando notificacoes via WhatsApp")
        vencimentos = self.vencimentos.buscar_proximos(3)
        self.whatsapp.enviar_alertas_vencimentos(vencimentos)

    # =========================================================
    # ANALISE DE PLANILHAS
    # =========================================================

    def analisar_planilha(self, arquivo: str):
        """
        Analisa planilhas contabeis:
        - Identifica erros e inconsistencias
        - Sugere correcoes
        - Aplica formulas contabeis corretas
        - Gera graficos e dashboards
        - Valida totais e balancetes
        """
        self.logger.info(f"Analisando planilha: {arquivo}")
        return self.planilhas.analisar(arquivo)

    # =========================================================
    # DOCUMENTOS WORD
    # =========================================================

    def gerar_documento_word(self, template: str, dados: Optional[dict] = None):
        """
        Gera documentos Word automaticamente:
        - Contratos sociais
        - Cartas de notificacao
        - Declaracoes contabeis
        - Relatorios gerenciais formatados
        - Procuracoes
        """
        self.logger.info(f"Gerando documento Word com template: {template}")
        return self.word.preencher_template(template, dados or {})

    # =========================================================
    # WEB SCRAPING FISCAL
    # =========================================================

    def scraping_fiscal(self, portal: str, cnpj: Optional[str] = None):
        """
        Coleta informacoes de portais fiscais:
        - Receita Federal: situacao cadastral, pendencias
        - e-CAC: declaracoes, intimacoes, processos
        - SEFAZ: situacao ICMS, inscricao estadual
        - Simples Nacional: opcao, situacao, sublimites
        """
        self.logger.info(f"Web scraping: {portal}")
        return self.scraping.coletar(portal, cnpj)

    # =========================================================
    # OBRIGACOES SPED/ECF
    # =========================================================

    def verificar_obrigacoes_sped(self):
        """
        Verifica status das obrigacoes acessorias:
        - SPED Contabil (ECD)
        - SPED Fiscal (EFD ICMS/IPI)
        - EFD Contribuicoes (PIS/COFINS)
        - ECF (Escrituracao Contabil Fiscal)
        - DCTF (Declaracao de Debitos e Creditos Tributarios Federais)
        - DIRF
        - RAIS / CAGED
        """
        self.logger.info("Verificando obrigacoes acessorias SPED/ECF")
        return self.obrigacoes.verificar_todas()
