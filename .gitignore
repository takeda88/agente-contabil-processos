# ============================================================
# .gitignore — Agente Contabil de Processos
# ============================================================

# ---- Credenciais e configuracoes sensiveis ----
.env
*.env
.env.*
!.env.example
!config.example.env

# ---- Banco de dados SQLite ----
*.db
*.sqlite
*.sqlite3
dados/agente_contabil.db

# ---- Segredos detectados ----
.secrets.baseline

# ---- Ambientes virtuais Python ----
venv/
.venv/
env/
ENV/

# ---- Cache Python ----
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Cobertura de testes ----
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# ---- Relatorios e logs gerados ----
dados/logs/*.log
dados/relatorios/*.xlsx
dados/relatorios/*.pdf

# ---- Backups manuais ----
*.bak
*.backup
*.orig

# ---- Distribuicao / Build ----
dist/
build/
*.egg-info/
.eggs/

# ---- IDEs e editores ----
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ---- Jupyter Notebooks ----
.ipynb_checkpoints/
