# ============================================================
# AGENTE CONTABIL - CONFIGURACOES
# Copie este arquivo para .env e preencha com seus dados reais
# cp config.example.env .env
# ============================================================

# ----------------------------
# E-MAIL (SMTP/IMAP)
# ----------------------------
EMAIL_USER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_app
EMAIL_SMTP=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_IMAP=imap.gmail.com
# Para Outlook:
# EMAIL_SMTP=smtp.office365.com
# EMAIL_IMAP=outlook.office365.com

# ----------------------------
# WHATSAPP (TWILIO)
# ----------------------------
# Obtenha em: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=sua_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ----------------------------
# INTELIGENCIA ARTIFICIAL
# ----------------------------
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=4000

# ----------------------------
# GOOGLE SHEETS
# ----------------------------
# Crie service account em: https://console.cloud.google.com
GOOGLE_CREDENTIALS_FILE=credentials.json
# ID da planilha principal (da URL do Google Sheets)
GOOGLE_SPREADSHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ----------------------------
# BANCO DE DADOS
# ----------------------------
DB_PATH=dados/agente_contabil.db
# Para PostgreSQL:
# DB_URL=postgresql://usuario:senha@localhost:5432/agente_contabil

# ----------------------------
# EMPRESA / ESCRITORIO
# ----------------------------
EMPRESA_NOME=Escritorio Contabil
EMPRESA_CNPJ=00.000.000/0001-00
EMPRESA_ENDERECO=Rua das Flores, 123 - Centro
EMPRESA_CIDADE=Goiania
EMPRESA_ESTADO=GO
EMPRESA_CEP=74000-000
EMPRESA_TELEFONE=(62) 99999-9999
EMPRESA_EMAIL=contato@escritorio.com.br
RESPONSAVEL_CRC=CRC-GO 999999/O

# ----------------------------
# CONFIGURACOES DO AGENTE
# ----------------------------
# Numero de dias de antecedencia para alertas de vencimento
ALERTA_VENCIMENTO_DIAS=5
# Horario de envio de relatorios (formato HH:MM)
HORARIO_RELATORIO_DIARIO=08:00
HORARIO_VERIFICACAO_EMAILS=*/30  # A cada 30 minutos
# Pasta raiz para monitoramento de arquivos
PASTA_MONITORAMENTO=C:/Contabilidade/Documentos
# Ativar modo debug (True/False)
DEBUG=False
# Nivel de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ----------------------------
# NOTIFICACOES - DESTINATARIOS
# ----------------------------
# E-mails separados por virgula
EMAIL_ALERTAS=gestor@escritorio.com.br,supervisor@escritorio.com.br
# Numeros WhatsApp para alertas (formato +5511999999999)
WHATSAPP_ALERTAS=+5562999999999,+5562988888888

# ----------------------------
# PORTAIS FISCAIS (WEB SCRAPING)
# ----------------------------
# Certificado digital para acesso ao e-CAC
CERTIFICADO_DIGITAL_PATH=certificados/cert.pfx
CERTIFICADO_DIGITAL_SENHA=senha_certificado
# Credenciais GOV.BR (opcional)
GOVBR_CPF=000.000.000-00
GOVBR_SENHA=sua_senha_govbr

# ----------------------------
# INTEGRACAO SOFTWARES CONTABEIS
# ----------------------------
# Dominio Sistemas
DOMINIO_URL=http://localhost:8080
DOMINIO_USUARIO=admin
DOMINIO_SENHA=senha_dominio
# Alterdata
ALTERDATA_URL=http://servidor-alterdata
ALTERDATA_USUARIO=usuario
ALTERDATA_SENHA=senha
